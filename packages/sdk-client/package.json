{
  "name": "@pramanasystems/sdk-client",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "description": "Type-safe SDK client for the PramanaSystems Runtime API.",
  "scripts": {
    "build": "tsup",
    "generate": "openapi-typescript ../../openapi.json -o src/openapi.d.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "devDependencies": {
    "openapi-typescript": "^7.13.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/pavancharak/PramanaSystems-core.git"
  },
  "homepage": "https://github.com/pavancharak/PramanaSystems-core",
  "bugs": {
    "url": "https://github.com/pavancharak/PramanaSystems-core/issues"
  },
  "keywords": [
    "sdk",
    "client",
    "governance",
    "attestation",
    "deterministic"
  ]
}
