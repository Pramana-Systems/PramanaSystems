{
  "compilerOptions": {
    "target": "ES2022",

    "module": "ESNext",

    "moduleResolution": "Bundler",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "baseUrl": ".",

    "paths": {
      "@manthan/bundle": [
        "./packages/bundle/src"
      ],

      "@manthan/crypto": [
        "./packages/crypto/src"
      ],

      "@manthan/governance": [
        "./packages/governance/src"
      ],

      "@manthan/cli": [
        "./packages/cli/src"
      ],

      "@manthan/runtime": [
        "./packages/runtime/src"
      ],

      "@manthan/verifier": [
        "./packages/verifier/src"
      ]
    }
  }
}