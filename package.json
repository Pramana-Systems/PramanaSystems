{
  "name": "manthan-core",

  "version": "1.0.0",

  "private": true,

  "packageManager": "npm@10.9.0",

  "workspaces": [
    "packages/*"
  ],

  "main": "index.js",

  "directories": {
    "doc": "docs",
    "test": "tests"
  },

  "scripts": {
    "test": "vitest run",

    "prepare": "husky",

    "export:openapi": "tsx ./scripts/export-openapi.ts",

    "typecheck": "tsc --noEmit",

    "check": "npm run typecheck && npm run test && npm run export:openapi",

    "bundle:manifest": "tsx ./scripts/regenerate-bundle.ts",

    "bundle:sign": "tsx ./scripts/sign-bundle.ts",

    "bundle:refresh": "npm run bundle:manifest && npm run bundle:sign",

    "build": "tsup",

    "build:watch": "tsup --watch",

    "build:packages": "turbo run build",

    "release:manifest": "tsx ./scripts/generate-release-manifest.ts",
    "release:sign": "tsx ./scripts/sign-release-manifest.ts",
     "release:verify": "tsx ./scripts/verify-release.ts"
  },

  "keywords": [],

  "author": "",

  "license": "ISC",

  "description": "",

  "devDependencies": {
    "@types/node": "^25.6.0",

    "husky": "^9.1.7",

    "openapi-typescript": "^7.13.0",

    "tsup": "^8.5.1",

    "tsx": "^4.21.0",

    "turbo": "^2.9.6",

    "typescript": "^5.8.3",

    "vitest": "^4.1.5"
  },

  "dependencies": {
    "@aws-sdk/client-kms": "^3.1038.0",

    "@fastify/swagger": "^9.7.0",

    "@fastify/swagger-ui": "^5.2.6",

    "fastify": "^5.8.5",

    "redis": "^5.12.1",

    "zod": "^4.3.6"
  }
}